{
  "manifest_version": 3,
  "name": "TM Tier Overlay",
  "version": "5.2",
  "description": "Tier ratings and overlays for Terraforming Mars",
  "permissions": ["storage"],
  "host_permissions": [
    "https://tm.knightbyte.win/*",
    "*://terraforming-mars.herokuapp.com/*",
    "*://tm.alrusdi.ru/*",
    "*://terraforming-mars.pe5ha.ru/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://terraforming-mars.herokuapp.com/*", "*://tm.knightbyte.win/*", "*://tm.alrusdi.ru/*", "*://terraforming-mars.pe5ha.ru/*"],
      "js": ["vue-bridge.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://terraforming-mars.herokuapp.com/*", "*://tm.knightbyte.win/*", "*://tm.alrusdi.ru/*", "*://terraforming-mars.pe5ha.ru/*"],
      "js": [
        "utils.js",
        "data/ratings.json.js",
        "data/combos.json.js",
        "data/names_ru.json.js",
        "data/card_effects.json.js",
        "data/scoring_config.json.js",
        "data/ma_data.json.js",
        "data/corps.json.js",
        "data/synergy_tables.json.js",
        "data/vp_multipliers.json.js",
        "data/card_tags.js",
        "data/card_vp.js",
        "data/card_data.js",
        "data/card_descriptions.js",
        "data/card_tag_reqs.js",
        "data/colony_data.js",
        "data/card_variants.js",
        "shared/brain-core.js",
        "shared/manual-ev.js",
        "tm-brain.js",
        "advisor-core.js",
        "advisor-workflow.js",
        "content-badges.js",
        "content-card-stats.js",
        "content-cycle.js",
        "content-draft-intel.js",
        "content-draft-history.js",
        "content-draft-poller.js",
        "content-draft-recommendations.js",
        "content-draft-tracker.js",
        "content-gen-timer.js",
        "content-game-signals.js",
        "content-game-overlays.js",
        "content-action-recommendation.js",
        "content-hand-ui.js",
        "content-hand-scores.js",
        "content-log-ui.js",
        "content-overlays.js",
        "content-route-validators.js",
        "content-play-priority.js",
        "content-player-meta.js",
        "content-player-view.js",
        "content-postgame.js",
        "content-prelude-package.js",
        "content-runtime-status.js",
        "content-standard-projects.js",
        "content-toast.js",
        "content-tooltip.js",
        "content-tooltip-state.js",
        "content-vp-breakdown.js",
        "content-vp-overlays.js",
        "content.js",
        "advisor-panel.js"
      ],
      "css": ["content.css", "advisor-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
