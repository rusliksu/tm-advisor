{
  "name": "tm-brain-tools",
  "required_files": [
    "tools/brain/test-core.js",
    "tools/brain/sync-core.js",
    "tools/brain/sync-card-variants.js",
    "tools/brain/sync-manual-ev.js",
    "tools/brain/calibrate-game-lengths.js",
    "scripts/test-tm-brain-core.js",
    "scripts/sync-tm-brain-core.js",
    "scripts/sync-tm-card-variants.js"
  ],
  "path_assertions": [
    {
      "path": "package.json",
      "contains": [
        "\"test:brain-core\": \"node tools/brain/test-core.js\"",
        "\"brain:check-card-variants\": \"node tools/brain/sync-card-variants.js --check\"",
        "\"brain:check-core\": \"node tools/brain/sync-core.js --check\"",
        "\"brain:check-manual-ev\": \"node tools/brain/sync-manual-ev.js --check\"",
        "\"brain:calibrate-game-lengths\": \"node tools/brain/calibrate-game-lengths.js\"",
        "\"brain:sync-card-variants\": \"node tools/brain/sync-card-variants.js\"",
        "\"brain:sync-core\": \"node tools/brain/sync-core.js\"",
        "\"brain:sync-manual-ev\": \"node tools/brain/sync-manual-ev.js\""
      ]
    },
    {
      "path": "scripts/test-tm-brain-core.js",
      "contains": [
        "const CANONICAL = path.resolve(__dirname, '..', 'tools', 'brain', 'test-core.js');",
        "process.exit(require(CANONICAL).main());"
      ]
    },
    {
      "path": "scripts/sync-tm-brain-core.js",
      "contains": [
        "const CANONICAL = path.resolve(__dirname, '..', 'tools', 'brain', 'sync-core.js');",
        "process.exit(require(CANONICAL).main(process.argv.slice(2)));"
      ]
    },
    {
      "path": "scripts/sync-tm-card-variants.js",
      "contains": [
        "const CANONICAL = path.resolve(__dirname, '..', 'tools', 'brain', 'sync-card-variants.js');",
        "process.exit(require(CANONICAL).main(process.argv.slice(2)));"
      ]
    },
    {
      "path": "tools/brain/sync-manual-ev.js",
      "contains": [
        "packages', 'tm-brain-js', 'src', 'manual-ev.js'",
        "extension', 'shared', 'manual-ev.js'",
        "bot', 'shared', 'manual-ev.js'"
      ]
    }
  ]
}
