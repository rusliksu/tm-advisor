{
  "name": "tm-architecture-tools",
  "required_files": [
    "tools/architecture/check-modules.js",
    "tools/architecture/run-suite.js",
    "scripts/check-app-boundaries.js"
  ],
  "path_assertions": [
    {
      "path": "package.json",
      "contains": [
        "\"arch:check-apps\": \"node tools/architecture/check-modules.js\"",
        "\"arch:check-modules\": \"node tools/architecture/check-modules.js\"",
        "\"check:all\": \"node tools/architecture/run-suite.js check:all\"",
        "\"sync:all\": \"node tools/architecture/run-suite.js sync:all\"",
        "\"test:fast\": \"node tools/architecture/run-suite.js test:fast\"",
        "\"test:architecture\": \"node tools/architecture/check-modules.js\""
      ]
    },
    {
      "path": "scripts/check-app-boundaries.js",
      "contains": [
        "const CANONICAL = path.resolve(__dirname, '..', 'tools', 'architecture', 'check-modules.js');",
        "process.exit(require(CANONICAL).run() ? 0 : 1);"
      ]
    }
  ]
}
